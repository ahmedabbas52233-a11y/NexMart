# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ecommerce?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# OAuth (Optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Vercel Blob (Optional — enables real image uploads in the admin product
# form. Create a Blob store in your Vercel project to get this token.
# Without it, admins can still paste an image URL directly.)
BLOB_READ_WRITE_TOKEN=""

# Resend (Optional — sends real password-reset emails. Get a free key at
# https://resend.com. Without it, the reset link is logged to the server
# console instead, so password reset still works for local testing.)
RESEND_API_KEY=""
EMAIL_FROM="NexMart <onboarding@resend.dev>"

# Upstash Redis (Recommended for production — real distributed rate limiting
# that actually holds across Vercel's multiple serverless instances, unlike
# the in-memory fallback used when these are unset. Free tier at
# https://upstash.com — create a Redis database, copy the REST URL/token.)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Test database (Optional — only used by __tests__/integration/, which
# fires real concurrent requests at a real Postgres instance to verify the
# atomic stock guard under genuine concurrency. Use a disposable database,
# e.g. a free Neon branch — never point this at production.)
TEST_DATABASE_URL=""

# Admin credentials (for seeding)
ADMIN_EMAIL="admin@ecommerce.com"
ADMIN_PASSWORD="Admin123!"
