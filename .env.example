# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ecommerce?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# OAuth (Optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Unsplash API (Optional — used by `npm run db:seed` to fetch accurate,
# relevant product photos. Get a free key at https://unsplash.com/developers.
# Without it, seeding falls back to a curated set of default images.)
UNSPLASH_ACCESS_KEY=""

# Vercel Blob (Optional — enables real image uploads in the admin product
# form. Create a Blob store in your Vercel project to get this token.
# Without it, admins can still paste an image URL directly.)
BLOB_READ_WRITE_TOKEN=""

# Resend (Optional — sends real password-reset emails. Get a free key at
# https://resend.com. Without it, the reset link is logged to the server
# console instead, so password reset still works for local testing.)
RESEND_API_KEY=""
EMAIL_FROM="NexMart <onboarding@resend.dev>"

# Admin credentials (for seeding)
ADMIN_EMAIL="admin@ecommerce.com"
ADMIN_PASSWORD="Admin123!"
